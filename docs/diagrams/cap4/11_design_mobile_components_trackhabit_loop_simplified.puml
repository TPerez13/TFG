@startuml
hide circle
hide methods
hide stereotypes

skinparam backgroundColor #F8FAFC
skinparam shadowing false
skinparam roundcorner 10
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam ArrowColor #5B7083
skinparam ArrowThickness 1
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam componentBackgroundColor #FFFFFF
skinparam componentBorderColor #6E879D
skinparam linetype ortho
skinparam nodesep 42
skinparam ranksep 46

title Diseño resumido de componentes de la aplicación móvil de TrackHabit Loop

top to bottom direction

component "App shell y sesión\nApp.tsx, NavigationContainer,\nAuthProvider" as mo_shell
component "Root navigation" as mo_root
component "Auth flow" as mo_auth
component "Main tabs" as mo_tabs
component "Módulo Hábitos y\nNutrición" as mo_habits
component "Módulo Progreso y\nLogros" as mo_progress
component "Módulo Perfil /\nAjustes / Soporte" as mo_profile
component "Subsistema de\nnotificaciones" as mo_notif
component "Infraestructura de cliente\napi.ts, AsyncStorage,\nshared contracts" as mo_infra
cloud "Backend API" as mo_backend

mo_shell --> mo_root
mo_shell --> mo_notif

mo_root --> mo_auth
mo_root --> mo_tabs

mo_tabs --> mo_habits
mo_tabs --> mo_progress
mo_tabs --> mo_profile

mo_habits ..> mo_notif
mo_profile ..> mo_notif

mo_auth --> mo_infra
mo_habits --> mo_infra
mo_progress --> mo_infra
mo_profile --> mo_infra
mo_notif --> mo_infra

mo_infra --> mo_backend

mo_shell -[hidden]down-> mo_root
mo_root -[hidden]down-> mo_tabs
mo_auth -[hidden]right-> mo_tabs
mo_tabs -[hidden]down-> mo_habits
mo_habits -[hidden]right-> mo_progress
mo_progress -[hidden]right-> mo_profile
mo_profile -[hidden]right-> mo_notif
mo_notif -[hidden]down-> mo_infra
mo_infra -[hidden]right-> mo_backend

@enduml
