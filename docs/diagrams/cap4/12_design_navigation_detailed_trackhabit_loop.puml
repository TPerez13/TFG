@startuml
allowmixing

skinparam backgroundColor #F8FAFC
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 12
skinparam ArrowColor #5B7083
skinparam ArrowThickness 1
skinparam packageStyle rectangle
skinparam linetype ortho

title Capítulo 4 - Navegación detallada de TrackHabit Loop

left to right direction

rectangle "Login" as login
rectangle "Recuperar acceso" as forgotPassword

frame "App autenticada" as authed {
  rectangle "Tabs\nInicio | Hábitos | Progreso | Perfil" as tabs

  frame "Inicio" {
    rectangle "Panel diario" as panelDiario
  }

  frame "Hábitos" {
    rectangle "Catálogo de hábitos" as habitsHome
    rectangle "Detalle / metas del hábito" as habitDetail
    rectangle "Nutrición" as nutrition
    rectangle "Registro rápido / manual\nde comida" as nutritionEntry
    rectangle "Hidratación" as hydration
    rectangle "Registrar agua" as hydrationEntry
    rectangle "Ejercicio" as exercise
    rectangle "Registrar ejercicio" as exerciseEntry
    rectangle "Sueño" as sleep
    rectangle "Registrar sueño" as sleepEntry
    rectangle "Meditación" as meditation
    rectangle "Registrar meditación" as meditationEntry
  }

  frame "Progreso" {
    rectangle "Resumen mensual" as monthlyProgress
    rectangle "Histórico" as history
    rectangle "Detalle por día" as dayHistoryDetail
    rectangle "Histórico por hábito" as habitHistory
    rectangle "Detalle de hábito" as progressHabitDetail
  }

  frame "Perfil" {
    rectangle "Perfil" as profile
    rectangle "Editar perfil" as editProfile
    rectangle "Logros" as achievements
    rectangle "Ajustes de notificaciones" as notificationSettings
    rectangle "Privacidad" as privacy
    rectangle "Soporte" as support
    rectangle "About" as about
    rectangle "Política de privacidad" as privacyPolicy
    rectangle "Términos de uso" as termsOfUse
  }
}

login --> forgotPassword : recuperar acceso
forgotPassword --> login : volver / completar reseteo
login --> tabs : autenticación correcta

tabs --> panelDiario : tab Inicio
tabs --> habitsHome : tab Hábitos
tabs --> monthlyProgress : tab Progreso
tabs --> profile : tab Perfil

panelDiario --> hydration : acceso rápido
panelDiario --> nutrition : acceso rápido
panelDiario --> exercise : acceso rápido
panelDiario --> sleep : acceso rápido
panelDiario --> meditation : acceso rápido
panelDiario --> achievements : teaser de logros

habitsHome --> habitDetail : ver detalle general
habitsHome --> nutrition : abrir nutrición
habitsHome --> hydration : abrir hidratación
habitsHome --> exercise : abrir ejercicio
habitsHome --> sleep : abrir sueño
habitsHome --> meditation : abrir meditación

nutrition --> nutritionEntry : registrar comida
hydration --> hydrationEntry : registrar
exercise --> exerciseEntry : registrar
sleep --> sleepEntry : registrar
meditation --> meditationEntry : registrar

monthlyProgress --> history : ver histórico
history --> dayHistoryDetail : explorar un día
history --> habitHistory : filtrar por hábito
habitHistory --> progressHabitDetail : ver detalle

profile --> editProfile
profile --> achievements
profile --> notificationSettings
profile --> privacy
profile --> support
profile --> about
profile --> privacyPolicy
profile --> termsOfUse
about --> privacyPolicy : acceso legal
about --> termsOfUse : acceso legal

note bottom of authed
Diagrama orientado a memoria del producto:
resume flujos de pantalla y no detalles
de implementación interna de React Navigation.
end note

@enduml
