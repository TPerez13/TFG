@startuml
hide circle
hide methods
hide stereotypes

skinparam backgroundColor #F8FAFC
skinparam shadowing false
skinparam roundcorner 10
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam ArrowColor #5B7083
skinparam ArrowThickness 1
skinparam packageStyle rectangle
skinparam packageBorderColor #9FB3C8
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #6E879D
skinparam noteBackgroundColor #FFF9E6
skinparam noteBorderColor #D7C58A
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 75
skinparam ranksep 45

title Capitulo 5 - Detalle relacional de gamificacion, avisos y soporte

left to right direction

package "Usuario de referencia" #EAF2FF {
  together {
    entity "usuario" as usuario {
      * id_usuario : SERIAL <<PK>>
      --
      * correo : TEXT <<UQ>>
      * nombre : TEXT
      preferencias : JSONB
      * f_creacion : TIMESTAMPTZ
    }

    entity "tipo_habito" as tipo_habito {
      * id_tipo_habito : SERIAL <<PK>>
      --
      * nombre : TEXT <<UQ>>
    }
  }
}

package "Gamificacion" #F4EEFF {
  together {
    entity "logro" as logro {
      * id_logro : SERIAL <<PK>>
      --
      * nombre : TEXT <<UQ>>
      criterio : JSONB
      * puntos : INT
    }

    entity "usuario_logro" as usuario_logro {
      * id_usuario_logro : SERIAL <<PK>>
      --
      * id_usuario : INT <<FK>>
      * id_logro : INT <<FK>>
      * f_obtencion : TIMESTAMPTZ
      * puntos : INT
      uq_usuario_logro : UNIQUE (id_usuario, id_logro)
    }

    entity "reto" as reto {
      * id_reto : SERIAL <<PK>>
      --
      * nombre : TEXT <<UQ>>
      objetivo : JSONB
      f_inicio : TIMESTAMPTZ
      f_fin : TIMESTAMPTZ
    }

    entity "usuario_reto" as usuario_reto {
      * id_usuario_reto : SERIAL <<PK>>
      --
      * id_usuario : INT <<FK>>
      * id_reto : INT <<FK>>
      * estado : TEXT <<CHECK>>
      * progreso : NUMERIC
      * f_inscripcion : TIMESTAMPTZ
      uq_usuario_reto : UNIQUE (id_usuario, id_reto)
    }
  }
}

package "Configuracion de avisos" #EAF7EA {
  together {
    entity "recordatorio" as recordatorio {
      * id_recordatorio : SERIAL <<PK>>
      --
      * id_usuario : INT <<FK>>
      * id_tipo_habito : INT <<FK>>
      * programacion : JSONB
      * activo : BOOLEAN
      * f_creacion : TIMESTAMPTZ
    }

    entity "user_device" as user_device {
      * id_user_device : SERIAL <<PK>>
      --
      * id_usuario : INT <<FK>>
      * platform : TEXT
      * expo_push_token : TEXT
      * created_at : TIMESTAMPTZ
      last_seen_at : TIMESTAMPTZ
    }
  }
}

package "Historico y soporte" #FFF5E8 {
  together {
    entity "notificacion" as notificacion {
      * id_notificacion : SERIAL <<PK>>
      --
      * id_usuario : INT <<FK>>
      * titulo : TEXT
      * cuerpo : TEXT
      * tipo : TEXT <<CHECK>>
      * estado : TEXT <<CHECK>>
      * leida : BOOLEAN
      f_leida : TIMESTAMPTZ
      f_programada : TIMESTAMPTZ
      f_envio : TIMESTAMPTZ
      metadatos : JSONB
      deep_link : TEXT
      * created_at : TIMESTAMPTZ
    }

    entity "ticket_soporte" as ticket_soporte {
      * id_ticket : SERIAL <<PK>>
      --
      * id_usuario : INT <<FK>>
      * asunto : TEXT
      * descripcion : TEXT
      * tipo : TEXT <<CHECK>>
      * estado : TEXT <<CHECK>>
      contacto_email : TEXT
      * f_creacion : TIMESTAMPTZ
    }
  }
}

usuario ||--o{ usuario_logro
logro ||--o{ usuario_logro
usuario ||--o{ usuario_reto
reto ||--o{ usuario_reto
usuario ||--o{ recordatorio
tipo_habito ||--o{ recordatorio
usuario ||--o{ user_device
usuario ||--o{ notificacion
usuario ||--o{ ticket_soporte

usuario_logro -[hidden]-> recordatorio
reto -[hidden]-> user_device
recordatorio -[hidden]-> ticket_soporte

note bottom of notificacion
Persistencia de eventos e historico de avisos.
No existe FK directa hacia logro, reto
o recordatorio; la relacion es semantica
mediante tipo y metadatos.
end note

@enduml
