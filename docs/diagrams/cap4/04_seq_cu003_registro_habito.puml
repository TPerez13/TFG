@startuml
' CAP4 - 04 Secuencia CU003 Registro de Habito

skinparam backgroundColor #F8FAFC
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 13
skinparam ArrowColor #5B7083
skinparam ArrowThickness 1
skinparam sequence {
  LifeLineBorderColor #6E879D
  LifeLineBackgroundColor #FFFFFF
  ParticipantBorderColor #6E879D
  ParticipantBackgroundColor #FFFFFF
}
skinparam noteBackgroundColor #FFF9E6
skinparam noteBorderColor #D7C58A

title CU003 - Registrar Habito (RF-003..RF-007)

participant "UI (App)" as UI
participant "API (Backend)" as API
database "DB (Persistencia)" as DB

UI -> API: POST /api/habits/entries\n{typeId, value, unit, dateTime, notes}
API -> API: Validar token + body
alt Datos invalidos
  API --> UI: 400/401 {message}
else Datos validos
  API -> DB: INSERT INTO registro_habito (...)
  DB --> API: entry creada
  API --> UI: 201 {entry}
end

opt Registro nutricional (flujo especifico)
  UI -> API: POST /api/nutrition/entries\n{tipoComida, kcal, ...}
  API -> DB: BEGIN
  API -> DB: INSERT INTO registro_comida (...)
  API -> DB: INSERT INTO registro_habito\n(type=2, id_registro_comida)
  API -> DB: COMMIT
  API --> UI: 201 {entry nutricion}
end

note over API,DB
TODO: no se detecto actualizacion de puntos/rachas
persistida en tablas de gamificacion tras registrar habito.
end note

@enduml
