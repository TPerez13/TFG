{
  "name": "trackhabit-loop-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "mobile-react-native",
    "packages/*"
  ],
  "scripts": {
    "build": "npm --prefix backend run build && npm --prefix packages/shared run build",
    "dev:backend": "npm --prefix backend run dev",
    "start:backend": "npm --prefix backend run start",
    "start:mobile": "npm --prefix mobile-react-native run start",
    "typecheck:mobile": "npm --prefix mobile-react-native run typecheck",
    "build:shared": "npm --prefix packages/shared run build",
    "db:up": "docker-compose up -d db pgadmin",
    "db:down": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d db pgadmin",
    "db:logs": "docker-compose logs -f db pgadmin",
    "android": "npm --prefix mobile-react-native run android",
    "ios": "npm --prefix mobile-react-native run ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "expo": "~54.0.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1"
  }
}
