PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/muchasvidas
SESSION_SECRET=change_me

# Password reset email defaults to disabled unless Resend is configured.
MAIL_PROVIDER=disabled

# When using Resend:
# - onboarding@resend.dev only sends to the owner email of the Resend account.
# - to send to real external recipients you need a verified domain and MAIL_FROM
#   must belong to that verified domain.
MAIL_FROM=
RESEND_API_KEY=
